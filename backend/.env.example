APP_NAME=AetherGuard API
ENVIRONMENT=development

# Model loading
MODEL_DIR=/opt/render/project/src/backend/model/trained_model
# Choose one remote source:
# MODEL_REPO_ID=rohitrane2002/aetherguard-codebert
# MODEL_REVISION=main
# HF_TOKEN=
# MODEL_SOURCE_URL=
ALLOW_BASE_MODEL_FALLBACK=false

# Database
DATABASE_URL=sqlite:///backend/aetherguard.db

# Auth
JWT_SECRET=replace-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_FREE=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=
STRIPE_SUCCESS_URL=https://aetherguard.vercel.app/account?checkout=success
STRIPE_CANCEL_URL=https://aetherguard.vercel.app/pricing?checkout=cancelled

# AI assistant
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1
AI_SYSTEM_PROMPT=You are AetherGuard Copilot. Explain Solidity vulnerabilities clearly, suggest concrete fixes, and stay concise.

# Security
MAX_SOLIDITY_CHARS=50000
USER_RATE_LIMIT_PER_MINUTE=30
IP_RATE_LIMIT_PER_MINUTE=60
API_KEY_RATE_LIMIT_PER_MINUTE=120
